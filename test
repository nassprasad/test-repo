	@printf '\nENVIRONMENT PARAMETERS\n'
	@printf '======================\n'
	@printf 'Environment    : %s\n' $(ENVIRONMENT)
	@printf 'AWS Region     : %s\n' $(AWS_REGION)
	@printf 'AWS Account ID : %s\n' $(AWS_ACCOUNT_ID)
