# Create log bucket for CloudFront and S3 access logs using project-logging module
# This module has the required permissions for CloudFront logging built-in
module "log_bucket" {
  source  = "repo.ihsmarkit.com/terraform__foundation/project-logging/aws"
  version = ">= 3.0"

  domain = var.log_bucket

  tags = {
    Purpose     = "logging"
    Environment = var.environment
  }
}

# S3 bucket policy for primary bucket (allows CloudFront access)
data "aws_iam_policy_document" "primary_bucket" {
  for_each = local.distributions

  statement {
    sid    = "AllowCloudFrontServicePrincipal"
    effect = "Allow"

    principals {
      type        = "Service"
      identifiers = ["cloudfront.amazonaws.com"]
    }

    actions = [
      "s3:GetObject"
    ]

    resources = [
      "arn:aws:s3:::${replace(lookup(each.value, "s3_bucket", "${each.key}-${var.environment}"), ".", "-")}/*"
    ]

    condition {
      test     = "StringEquals"
      variable = "AWS:SourceArn"
      values   = [module.cloudfront_distributions[each.key].arn]
    }
  }
}

# Create S3 buckets for CloudFront distributions
module "s3_buckets" {
  source  = "repo.ihsmarkit.com/terraform__foundation/bucket/aws"
  version = ">= 7.0"

  for_each = local.distributions

  name            = replace(lookup(each.value, "s3_bucket", "${each.key}-${var.environment}"), ".", "-")
  force_destroy   = false
  kms_key_id      = null
  log_bucket      = "logs.us-east-1.${var.log_bucket}"
  log_prefix      = "${each.key}/"
  cloudfront_arns = []

  # Use policy_documents parameter with data source (not cloudfront_arns)
  policy_documents = [
    data.aws_iam_policy_document.primary_bucket[each.key].json
  ]

  lifecycle_rules = {
    cleanup = {
      filter                        = { prefix = "" }
      transition                    = [{ days = 30, storage_class = "INTELLIGENT_TIERING" }]
      noncurrent_version_transition = [{ noncurrent_days = 7, storage_class = "INTELLIGENT_TIERING" }]
      noncurrent_version_expiration = { noncurrent_days = 30, newer_noncurrent_versions = 2 }
    }
  }

  tags = merge(
    lookup(each.value, "tags", {}),
    {
      Name         = each.key
      Environment  = var.environment
      Distribution = each.key
    }
  )
}

