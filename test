# Lambda Functions Configuration
# Lambda functions with optional API Gateway integration

locals {
  lambda_config = try(yamldecode(file("../../../config/${var.environment}/lambdas.yaml")), { lambdas = [] })
  lambdas       = { for lambda in local.lambda_config.lambdas : lambda.name => lambda }

  # Filter lambdas with API Gateway enabled
  api_gateway_lambdas = { for k, v in local.lambdas : k => v if lookup(lookup(v, "api_gateway", {}), "enabled", false) }
}

# Lambda Functions (foundation module handles IAM roles automatically)
module "lambda_functions" {
  source  = "repo.ihsmarkit.com/terraform__foundation/lambda/aws"
  version = ">= 4.0"

  for_each = local.lambdas

  name        = "${each.value.name}-${var.environment}"
  description = lookup(each.value, "description", "Lambda function for ${each.value.name}")

  runtime     = each.value.runtime
  handler     = each.value.handler
  timeout     = lookup(each.value, "timeout", 30)
  memory_size = lookup(each.value, "memory_size", 256)

  # Code deployment from S3
  deployment = {
    package_type = "zip"
    zip = {
      bucket = {
        name = each.value.s3_bucket
        key  = each.value.s3_key
      }
    }
  }

  # Environment variables
  env = lookup(each.value, "environment_variables", null)

  # Tags from YAML config only (module handles Name, Environment, ManagedBy automatically)
  tags = lookup(each.value, "tags", {})
}

# API Gateway for Lambda Functions (optional)
# Creates API Gateway REST API for each Lambda function that has API Gateway enabled
module "api_gateway" {
  source = "../../../modules/api-gateway"

  for_each = local.api_gateway_lambdas

  name        = "${each.value.name}-${var.environment}-api"
  description = "API Gateway for ${each.value.name}"

  # Lambda integration
  lambda_invoke_arn    = module.lambda_functions[each.key].invoke_arn
  lambda_function_name = module.lambda_functions[each.key].name

  # API Gateway configuration from lambdas.yaml
  path_part   = lookup(each.value.api_gateway, "path", each.value.name)
  http_method = lookup(each.value.api_gateway, "http_method", "ANY")
  stage_name  = lookup(each.value.api_gateway, "stage_name", var.environment)

  # Monitoring and logging
  enable_xray        = lookup(each.value.api_gateway, "enable_xray", true)
  enable_metrics     = lookup(each.value.api_gateway, "enable_metrics", true)
  log_level          = lookup(each.value.api_gateway, "log_level", "INFO")
  log_retention_days = lookup(each.value, "log_retention_days", 14)
  enable_data_trace  = lookup(each.value.api_gateway, "enable_data_trace", false)

  # Throttling
  throttling_burst_limit = lookup(each.value.api_gateway, "throttling_burst_limit", 5000)
  throttling_rate_limit  = lookup(each.value.api_gateway, "throttling_rate_limit", 10000)

  tags = merge(
    lookup(each.value, "tags", {}),
    {
      Name        = "${each.value.name}-${var.environment}-api"
      Environment = var.environment
      ManagedBy   = "Terraform"
    }
  )
}

