# Load distributions configuration from YAML
locals {
  distributions_raw = yamldecode(file(var.distributions_config_file))

  # Extract Route53 Zone ID from config
  route53_zone_id = local.distributions_raw.route53_zone_id

  # Filter only enabled distributions
  distributions = {
    for dist in local.distributions_raw.distributions :
    dist.name => dist
    if lookup(dist, "enabled", true)
  }

  # Bucket regional domain names for CloudFront origin (buckets created in same state using module)
  bucket_regional_domain_names = {
    for name, dist in local.distributions :
    name => "${replace(lookup(dist, "s3_bucket", "${name}-${var.environment}"), ".", "-")}.s3.${var.aws_region}.amazonaws.com"
  }

  # CloudFront distribution configurations
  cloudfront_distributions = {
    for name, dist in local.distributions :
    name => {
      domain = dist.domain
      # Use certificate_arn from config, no auto-creation for local testing
      certificate_arn        = dist.certificate_arn
      zone_id                = lookup(lookup(dist, "dns", {}), "zone_id", local.route53_zone_id)
      dns_names              = lookup(lookup(dist, "dns", {}), "aliases", ["."])
      root_object            = lookup(lookup(dist, "cloudfront", {}), "root_object", "index.html")
      error_object           = lookup(lookup(dist, "cloudfront", {}), "error_object", "/index.html")
      price_class            = lookup(lookup(dist, "cloudfront", {}), "price_class", "PriceClass_100")
      viewer_protocol_policy = lookup(lookup(dist, "cloudfront", {}), "viewer_protocol_policy", "redirect-to-https")
      enable_spa_handling    = lookup(lookup(dist, "cloudfront", {}), "enable_spa_handling", true)

      # Authentication
      oidc_client_id = lookup(lookup(dist, "authentication", {}), "oidc_client_id", null)
      oidc_issuer    = lookup(lookup(dist, "authentication", {}), "oidc_issuer", "https://sam.ihsmarkit.com:443/sso/oauth2")
      oidc_scopes    = toset(lookup(lookup(dist, "authentication", {}), "oidc_scopes", ["openid", "email", "profile"]))
      auth_dns_name  = lookup(lookup(dist, "authentication", {}), "auth_dns_name", null)

      # Failover
      secondary_bucket      = lookup(lookup(dist, "cloudfront", {}), "secondary_bucket", null)
      failover_status_codes = toset(lookup(lookup(lookup(dist, "cloudfront", {}), "failover", {}), "status_codes", [500, 502, 503, 504]))

      # Custom headers
      custom_headers = lookup(dist, "headers", {})

      # Cache configuration
      cache_min_ttl            = lookup(lookup(lookup(dist, "cloudfront", {}), "cache", {}), "min_ttl", 0)
      cache_default_ttl        = lookup(lookup(lookup(dist, "cloudfront", {}), "cache", {}), "default_ttl", 0)
      cache_max_ttl            = lookup(lookup(lookup(dist, "cloudfront", {}), "cache", {}), "max_ttl", 0)
      use_managed_cache_policy = lookup(lookup(dist, "cloudfront", {}), "use_managed_cache_policy", false)
      cache_policy_id          = lookup(lookup(dist, "cloudfront", {}), "cache_policy_id", null)
      origin_request_policy_id = lookup(lookup(dist, "cloudfront", {}), "origin_request_policy_id", null)

      # Tags
      tags = lookup(dist, "tags", {})
    }
  }
}

